{
  "env": {
    "CLAUDE_CODE_SCROLL_SPEED": "0.25",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Glob",
      "WebSearch",
      "WebFetch",
      "PowerShell",
